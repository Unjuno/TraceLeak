    "produces_format": "traceleak.model_sequence.v1",
    "output_kind": "model_sequence_token_counts",
    "required_record_fields": [
      "run_id",
      "target",
      "target_version",
      "view",
      "label",
      "token_counts"
    ]
  },
  "labels": {
    "lab_only": true,
    "label_source": "post_collection_public_redacted_metadata",
    "allowed_label_keys": [
      "rsa_keygen_attempt_bucket"
    ]
  },
  "safety": {
