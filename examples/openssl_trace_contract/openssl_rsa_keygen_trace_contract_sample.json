      "event_token",
      "source_token",
      "context_token",
      "event_type",
      "phase",
      "count"
    ],
    "disallowed_fields": [
      "p",
      "q",
      "d",
      "private_key",
      "raw_bignum",
      "prime_candidate",
      "seed",
      "rng_state"
